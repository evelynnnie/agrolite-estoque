{
  "compilerOptions": {
    
    "target": "ES2022",                          
    "module": "NodeNext",                        
    "moduleResolution": "NodeNext",
    "rootDir": "./src",                          
    "outDir": "./dist",                          

    "strict": true,                             
    "noImplicitAny": true,                      
    "strictNullChecks": true,                  
    
    "noUnusedLocals": true,                    
    "noUnusedParameters": true,               
    "skipLibCheck": true,                   
    
    "esModuleInterop": true,                     
    "forceConsistentCasingInFileNames": true     
  },
  "include": ["src/**/*"]                        
}